    MySQL --> Debezium
    Postgres --> Debezium
    S3Raw --> Firehose
    Kafka --> Firehose
    API --> Airbyte
    SFTP --> Custom
    Debezium --> S3Landing
    Firehose --> S3Landing
    Airbyte --> S3Landing
    Custom --> S3Landing
